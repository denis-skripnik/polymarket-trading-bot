# Required configuration
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_ALLOWED_USER_ID=your_telegram_user_id

# Recommended for stable operation
POLYGON_RPC_URL=https://polygon-rpc.com
# Etherscan V2 API key works for both Ethereum and Polygon
ETHERSCAN_API_KEY=your_etherscan_api_key

# Optional: outbound proxy for HTTP(S)/RPC/WebSocket traffic
# Format: https://login:password@ip:port
PROXY=
# Optional: outbound HTTP timeout for axios/clob-client requests (ms)
# OUTBOUND_HTTP_TIMEOUT_MS=20000

# Optional/advanced parameters are documented in README.md
